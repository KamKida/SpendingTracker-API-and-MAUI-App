<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SpendingTrackerApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SpendingTrackerApp.Pages"
    xmlns:funds="clr-namespace:SpendingTrackerApp.Pages.LoginPages"
    xmlns:fundCat="clr-namespace:SpendingTrackerApp.Pages.FundCategorysPages"
    xmlns:spendings="clr-namespace:SpendingTrackerApp.Pages.SpendingPages"
    xmlns:start="clr-namespace:SpendingTrackerApp"

    Title="SpendingTrackerApp"
    FlyoutBehavior="Flyout">

	<FlyoutItem
        Icon="home.png"
        Title="Meny główne">
		<ShellContent
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage"/>
	</FlyoutItem>

	<FlyoutItem
        Icon="funds.png"
        Title="Historia funduszy">
		<ShellContent
            ContentTemplate="{DataTemplate funds:FundsHistoryPage}"
            Route="FundsHistoryPage"/>
	</FlyoutItem>

	<FlyoutItem
    Icon="funds_category.png"
    Title="Lista kategori funduszy">
		<ShellContent
        ContentTemplate="{DataTemplate fundCat:FundCategoryList}"
        Route="FundCategoryList"/>
	</FlyoutItem>

	<FlyoutItem
    Icon="spending.png"
    Title="Historia wydatków">
		<ShellContent
        ContentTemplate="{DataTemplate spendings:SpendingHistoryPage}"
        Route="SpendingHistoryPage"/>
	</FlyoutItem>

</Shell>

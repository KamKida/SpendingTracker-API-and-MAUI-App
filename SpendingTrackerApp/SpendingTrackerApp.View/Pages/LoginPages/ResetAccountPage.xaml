<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpendingTrackerApp.Pages.EditPasswordPage"
             Title="Resetuj hasło">
    <Grid Style="{StaticResource PrimaryTheme}">

        <Grid
            RowDefinitions="Auto,Auto,Auto,Auto"
            RowSpacing="10">

        <Border Grid.Row="0">
            <Entry 
                Placeholder="Email"
                Text ="{Binding Request.Email}"/>
        </Border>


        <Border Grid.Row="1">
            <Entry 
                Grid.Column="0"
                Placeholder="Password"
                Text="{Binding Request.Password}"/>
        </Border>


        <Button 
            Grid.Row="2"
            Text="Resetuj hasło"
            FontSize="20"
            WidthRequest="200"
            Command ="{Binding ResetAccountCommand}"/>


        <Border
            Grid.Row="3">
            <Label 
                Text="{Binding Message}"
                TextColor="{Binding MessageColor}"
                IsVisible="{Binding ShowMessage}"
                FontSize="20"/>
        </Border>


        </Grid>
        <Grid
            IsVisible="{Binding ShowLoadingIcon}"
            BackgroundColor="#80000000"
            ZIndex="999">

            <ActivityIndicator
                IsRunning="{Binding RunLoadingIcon}"
                Color="DodgerBlue"
                WidthRequest="80"
                HeightRequest="80"
                HorizontalOptions="Center"
                VerticalOptions="Center"/>
        </Grid>
    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpendingTrackerApp.Pages.MainPage"
             Title="Główna strona">
    
    <ScrollView
        BackgroundColor="White">
        <Grid
            RowDefinitions="Auto ,Auto ,Auto ,*"
            ColumnDefinitions="Auto, *"
            Padding="10"
            RowSpacing="10">

            <Label
            Text="0"
            Grid.Row="0"
            Grid.Column="0"
            FontSize="45"
            TextColor="Green"/>

            <Label
            Text="0"
            Grid.Row="1"
            FontSize="25"
            Grid.Column="0"/>

            
            
            <ImageButton
                Grid.Row="0"
                Grid.Column="1"
                Source="add.png"
                HeightRequest="35"
                WidthRequest="35"
                HorizontalOptions="End"
                VerticalOptions="Center"/>

            <ImageButton
                Grid.Row="1"
                Grid.Column="1"
                Source="history.png"
                HeightRequest="35"
                WidthRequest="35"
                HorizontalOptions="End"
                VerticalOptions="Center"/>

        </Grid>
    </ScrollView>
</ContentPage>